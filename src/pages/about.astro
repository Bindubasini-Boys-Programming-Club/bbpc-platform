---
import DocsLayout from "@/layouts/DocsLayout.astro";
import Prose from "@/components/docs/Prose.astro";

---

<DocsLayout title="About" description="BBPC overview and mission.">
  <Prose>
    <h2>About BBPC</h2>
    <p>
      BBPC (Bindubasini Boys Programming Club) is a student-run community focused on building
      real-world software, leveling up programming fundamentals, and collaborating through
      workshops and project sprints.
    </p>

    <h3>Our mission</h3>
    <ul>
      <li>Learn by building: ship projects every month</li>
      <li>Mentorship-first culture: reviewers help members grow</li>
      <li>Inclusive learning: beginners welcome</li>
    </ul>

    <h3>What we do</h3>
    <ul>
      <li>Workshops on DSA, web development, and tooling</li>
      <li>Hackathons and demo days</li>
      <li>Team projects with rotating leads</li>
    </ul>
  </Prose>
</DocsLayout>

