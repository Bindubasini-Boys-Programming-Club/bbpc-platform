---
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import { AstroSeo } from "@lexingtonthemes/seo";
import { siteConfig } from "@/config/site";
// Icons
import HugeIcon from "@/components/fundations/icons/HugeIcon.astro";
import { PlusSignIcon } from "@/lib/hugeicons";

const canonical = `${siteConfig.url}${Astro.url.pathname || "/"}`;
---

<AstroSeo
  title={`System Buttons | ${siteConfig.name}`}
  description="Button styles and states."
  canonical={canonical}
  openGraph={{
    url: canonical,
    title: `System Buttons | ${siteConfig.name}`,
    description: "Button styles and states.",
    site_name: siteConfig.name,
    type: "website",
    locale: "en_US",
    images: [
      {
        url: siteConfig.ogImage,
        width: 1200,
        height: 630,
        alt: `${siteConfig.name} Open Graph image`,
        type: "image/jpeg",
      },
    ],
  }}
  twitter={{
    cardType: "summary_large_image",
    site: siteConfig.author.twitter,
    handle: siteConfig.author.twitter,
  }}
/>
<BaseLayout>
  <section>
    <Wrapper variant="standard" class="py-12 lg:py-24">
      <Text tag="h2" variant="displaySM" class="font-medium text-base-900">
        Buttons
      </Text>

      <div
        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12 text-base-400 mt-12"
      >
        <!-- Default -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div>
            <Text
              tag="p"
              variant="textXS"
              class="font-medium uppercase text-base-900"
            >
              Default text
            </Text>
            <div class="flex flex-col mt-2 gap-4">
              <Button size="xxs" variant="default">Default XXS</Button>
              <Button size="xs" variant="default">Default XS</Button>
              <Button size="sm" variant="default">Default SM</Button>
              <Button size="base" variant="default">Default Base</Button>
              <Button size="md" variant="default">Default MD</Button>
              <Button size="lg" variant="default">Default LG</Button>
              <Button size="xl" variant="default">Default XL</Button>
            </div>
          </div>
          <div>
            <Text
              tag="p"
              variant="textXS"
              class="font-medium uppercase text-base-900"
            >
              Icon
            </Text>
            <div class="flex flex-col mt-2 gap-4">
              <Button size="xxs" variant="default" iconOnly
                ><HugeIcon slot="icon" icon={PlusSignIcon} size="sm" /></Button
              >
              <Button size="xs" variant="default" iconOnly
                ><HugeIcon slot="icon" icon={PlusSignIcon} size="sm" /></Button
              >
              <Button size="sm" variant="default" iconOnly
                ><HugeIcon slot="icon" icon={PlusSignIcon} size="base" /></Button
              >
              <Button size="base" variant="default" iconOnly
                ><HugeIcon slot="icon" icon={PlusSignIcon} size="base" /></Button
              >
              <Button size="md" variant="default" iconOnly
                ><HugeIcon slot="icon" icon={PlusSignIcon} size="lg" /></Button
              >
              <Button size="lg" variant="default" iconOnly
                ><HugeIcon slot="icon" icon={PlusSignIcon} size="xl" /></Button
              >
              <Button size="xl" variant="default" iconOnly
                ><HugeIcon slot="icon" icon={PlusSignIcon} size="xl" /></Button
              >
            </div>
          </div>
        </div>
        <!-- Accent -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div>
            <Text
              tag="p"
              variant="textXS"
              class="font-medium uppercase text-base-900"
            >
              Accent text
            </Text>
            <div class="flex flex-col mt-2 gap-4">
              <Button size="xxs" variant="accent">Accent XXS</Button>
              <Button size="xs" variant="accent">Accent XS</Button>
              <Button size="sm" variant="accent">Accent SM</Button>
              <Button size="base" variant="accent">Accent Base</Button>
              <Button size="md" variant="accent">Accent MD</Button>
              <Button size="lg" variant="accent">Accent LG</Button>
              <Button size="xl" variant="accent">Accent XL</Button>
            </div>
          </div>
          <div>
            <Text
              tag="p"
              variant="textXS"
              class="font-medium uppercase text-base-900"
            >
              Icon
            </Text>
            <div class="flex flex-col mt-2 gap-4">
              <Button size="xxs" variant="accent" iconOnly
                ><HugeIcon slot="icon" icon={PlusSignIcon} size="sm" /></Button
              >
              <Button size="xs" variant="accent" iconOnly
                ><HugeIcon slot="icon" icon={PlusSignIcon} size="sm" /></Button
              >
              <Button size="sm" variant="accent" iconOnly
                ><HugeIcon slot="icon" icon={PlusSignIcon} size="base" /></Button
              >
              <Button size="base" variant="accent" iconOnly
                ><HugeIcon slot="icon" icon={PlusSignIcon} size="base" /></Button
              >
              <Button size="md" variant="accent" iconOnly
                ><HugeIcon slot="icon" icon={PlusSignIcon} size="lg" /></Button
              >
              <Button size="lg" variant="accent" iconOnly
                ><HugeIcon slot="icon" icon={PlusSignIcon} size="xl" /></Button
              >
              <Button size="xl" variant="accent" iconOnly
                ><HugeIcon slot="icon" icon={PlusSignIcon} size="xl" /></Button
              >
            </div>
          </div>
        </div>
        <!-- Muted -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div>
            <Text
              tag="p"
              variant="textXS"
              class="font-medium uppercase text-base-900"
            >
              Muted text
            </Text>
            <div class="flex flex-col mt-2 gap-4">
              <Button size="xxs" variant="muted">Muted XXS</Button>
              <Button size="xs" variant="muted">Muted XS</Button>
              <Button size="sm" variant="muted">Muted SM</Button>
              <Button size="base" variant="muted">Muted Base</Button>
              <Button size="md" variant="muted">Muted MD</Button>
              <Button size="lg" variant="muted">Muted LG</Button>
              <Button size="xl" variant="muted">Muted XL</Button>
            </div>
          </div>
          <div>
            <Text
              tag="p"
              variant="textXS"
              class="font-medium uppercase text-base-900"
            >
              Icon
            </Text>
            <div class="flex flex-col mt-2 gap-4">
              <Button size="xxs" variant="muted" iconOnly
                ><HugeIcon slot="icon" icon={PlusSignIcon} size="sm" /></Button
              >
              <Button size="xs" variant="muted" iconOnly
                ><HugeIcon slot="icon" icon={PlusSignIcon} size="sm" /></Button
              >
              <Button size="sm" variant="muted" iconOnly
                ><HugeIcon slot="icon" icon={PlusSignIcon} size="base" /></Button
              >
              <Button size="base" variant="muted" iconOnly
                ><HugeIcon slot="icon" icon={PlusSignIcon} size="base" /></Button
              >
              <Button size="md" variant="muted" iconOnly
                ><HugeIcon slot="icon" icon={PlusSignIcon} size="lg" /></Button
              >
              <Button size="lg" variant="muted" iconOnly
                ><HugeIcon slot="icon" icon={PlusSignIcon} size="xl" /></Button
              >
              <Button size="xl" variant="muted" iconOnly
                ><HugeIcon slot="icon" icon={PlusSignIcon} size="xl" /></Button
              >
            </div>
          </div>
        </div>
      </div>
    </Wrapper>
  </section>
</BaseLayout>
