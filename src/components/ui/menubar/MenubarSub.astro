---
import { cn } from "@/utils/cn";
import type { HTMLAttributes } from "astro/types";

export interface Props extends HTMLAttributes<"div"> {}

const { class: className, ...props } = Astro.props;

const classes = cn("relative", className);
---

<div class={classes} data-menubar-sub {...props}>
  <slot />
</div>

<script>
  function initMenubarSubs() {
    document.querySelectorAll("[data-menubar-sub]").forEach((sub) => {
      if (sub.hasAttribute("data-sub-initialized")) return;
      sub.setAttribute("data-sub-initialized", "true");

      const trigger = sub.querySelector("[data-menubar-sub-trigger]");
      const content = sub.querySelector("[data-menubar-sub-content]");

      if (!trigger || !content) return;

      const triggerEl = trigger as HTMLElement;
      const contentEl = content as HTMLElement;

      let closeTimeout: ReturnType<typeof setTimeout>;

      function openSubmenu() {
        clearTimeout(closeTimeout);
        contentEl.removeAttribute("hidden");
        triggerEl.setAttribute("data-state", "open");
        triggerEl.setAttribute("aria-expanded", "true");
      }

      function closeSubmenu() {
        closeTimeout = setTimeout(() => {
          contentEl.setAttribute("hidden", "");
          triggerEl.setAttribute("data-state", "closed");
          triggerEl.setAttribute("aria-expanded", "false");
        }, 100);
      }

      triggerEl.addEventListener("mouseenter", openSubmenu);
      triggerEl.addEventListener("mouseleave", closeSubmenu);
      contentEl.addEventListener("mouseenter", () => clearTimeout(closeTimeout));
      contentEl.addEventListener("mouseleave", closeSubmenu);

      triggerEl.addEventListener("keydown", (e) => {
        const event = e as KeyboardEvent;
        if (event.key === "ArrowRight" || event.key === "Enter" || event.key === " ") {
          event.preventDefault();
          event.stopPropagation();
          openSubmenu();
          const firstItem = contentEl.querySelector(
            "[data-menubar-focusable]:not([data-disabled])",
          ) as HTMLElement;
          if (firstItem) firstItem.focus();
        }
      });

      contentEl.addEventListener("keydown", (e) => {
        const event = e as KeyboardEvent;
        if (event.key === "ArrowLeft" || event.key === "Escape") {
          event.preventDefault();
          event.stopPropagation();
          closeSubmenu();
          triggerEl.focus();
        }
      });
    });
  }

  initMenubarSubs();
  document.addEventListener("astro:page-load", initMenubarSubs);
</script>
