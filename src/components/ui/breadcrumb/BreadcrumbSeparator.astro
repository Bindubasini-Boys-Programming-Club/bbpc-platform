---
import { cn } from "@/utils/cn";
import type { HTMLAttributes } from "astro/types";
import HugeIcon from "@/components/fundations/icons/HugeIcon.astro";
import { ArrowRight01Icon } from "@/lib/hugeicons";

export interface Props extends HTMLAttributes<"li"> {}

const { class: className, ...props } = Astro.props;

const classes = cn("[&>svg]:size-3.5", className);
---

<li role="presentation" aria-hidden="true" class={classes} {...props}>
  <slot>
    <HugeIcon icon={ArrowRight01Icon} />
  </slot>
</li>
