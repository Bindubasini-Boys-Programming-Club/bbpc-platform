---
import { cn } from "@/utils/cn";
import type { HTMLAttributes } from "astro/types";
import HugeIcon from "@/components/fundations/icons/HugeIcon.astro";
import { ArrowDown01Icon } from "@/lib/hugeicons";

export interface Props extends HTMLAttributes<"button"> {
  defaultOpen?: boolean;
}

const { defaultOpen = false, class: className, ...props } = Astro.props;

const classes = cn(
  "flex w-full flex-1 items-center justify-between py-4 font-medium transition-all hover:TextUnderlineIcon [&[data-state=open]>svg]:rotate-180",
  className
);
---

<button
  type="button"
  class={classes}
  data-accordion-trigger
  data-state={defaultOpen ? "open" : "closed"}
  aria-expanded={defaultOpen}
  {...props}
>
  <slot />
  <HugeIcon icon={ArrowDown01Icon} size={16} class="shrink-0 transition-transform duration-200" />
</button>
