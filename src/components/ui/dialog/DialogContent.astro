---
import { cn } from "@/utils/cn";
import type { HTMLAttributes } from "astro/types";
import HugeIcon from "@/components/fundations/icons/HugeIcon.astro";
import { Cancel01Icon } from "@/lib/hugeicons";

export interface Props extends HTMLAttributes<"div"> {}

const { class: className, ...props } = Astro.props;

const classes = cn(
  "fixed left-1/2 top-1/2 z-50",
  "-translate-x-1/2 -translate-y-1/2",
  "w-[480px] max-w-[calc(100vw-2rem)]",
  "rounded-2xl border border-border/60",
  "bg-background/95 backdrop-blur-xl",
  "p-8",
  "shadow-[0_25px_80px_rgba(0,0,0,0.45)]",
  "duration-300",
  className,
);
---

<div
  class={classes}
  data-dialog-content
  hidden
  role="dialog"
  aria-modal="true"
  {...props}
>
  <slot />

  <button
    type="button"
    class="absolute right-5 top-5 inline-flex h-11 w-11 items-center justify-center rounded-full border border-border/60 bg-background/70 text-muted-foreground transition-all duration-200 hover:scale-105 hover:bg-accent hover:text-foreground focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2"
    data-dialog-close
    aria-label="Close dialog"
  >
    <HugeIcon icon={Cancel01Icon} size={26} />
    <span class="sr-only">Close</span>
  </button>
</div>