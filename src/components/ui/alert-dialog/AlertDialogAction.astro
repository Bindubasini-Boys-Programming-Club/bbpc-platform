---
import Button from '@/components/ui/button/Button.astro';

export interface Props {
  variant?: "default" | "destructive";
  class?: string;
  disabled?: boolean;
  type?: "button" | "submit" | "reset";
}

const {
  variant = "default",
  class: className,
  disabled,
  type = "button",
} = Astro.props;
---

<Button
  variant={variant}
  size="sm"
  class={className}
  disabled={disabled}
  type={type}
  data-alert-dialog-action
>
  <slot />
</Button>
