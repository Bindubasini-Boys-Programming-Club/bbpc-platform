---
import Button from '@/components/ui/button/Button.astro';

export interface Props {
  class?: string;
  disabled?: boolean;
  type?: "button" | "submit" | "reset";
}

const { class: className, disabled, type = "button" } = Astro.props;
---

<Button
  variant="outline"
  size="sm"
  class={className}
  disabled={disabled}
  type={type}
  data-alert-dialog-cancel
>
  <slot />
</Button>
