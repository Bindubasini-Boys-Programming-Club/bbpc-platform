---
import Button from "@/components/ui/button/Button.astro";
import HugeIcon from "@/components/fundations/icons/HugeIcon.astro";
import { ArrowLeft01Icon, ArrowRight01Icon } from "@/lib/hugeicons";

export interface Props {
  prevPage?: { href: string; title: string } | null;
  nextPage?: { href: string; title: string } | null;
}

const { prevPage, nextPage } = Astro.props;
---

<div class="flex items-center gap-1">
  {
    prevPage ? (
      <Button
        href={prevPage.href}
        variant="secondary"
        size="xs"
        iconOnly
        title={`Previous: ${prevPage.title}`}
        data-pagination-prev
      >
        <HugeIcon icon={ArrowLeft01Icon} />
      </Button>
    ) : (
      <Button variant="secondary" size="xs" iconOnly disabled>
        <HugeIcon icon={ArrowLeft01Icon} />
      </Button>
    )
  }
  {
    nextPage ? (
      <Button
        href={nextPage.href}
        variant="secondary"
        size="xs"
        iconOnly
        title={`Next: ${nextPage.title}`}
        data-pagination-next
      >
        <HugeIcon icon={ArrowRight01Icon} />
      </Button>
    ) : (
      <Button variant="secondary" size="xs" iconOnly disabled>
        <HugeIcon icon={ArrowRight01Icon} />
      </Button>
    )
  }
</div>
