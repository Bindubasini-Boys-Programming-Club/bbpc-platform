---
import { cn } from "@/utils/cn";
import Text from "@/components/fundations/elements/Text.astro";
import HugeIcon from "@/components/fundations/icons/HugeIcon.astro";
import { Tick02Icon, InformationCircleIcon, Alert02Icon, Cancel01Icon } from "@/lib/hugeicons";

const { title, variant = "info", class: className, ...props } = Astro.props;

const variants = {
  do: {
    title: "Do",
    icon: Tick02Icon,
    card: "bg-success/5",
    text: "text-success",
  },
  dont: {
    title: "Don't",
    icon: Cancel01Icon,
    card: "bg-destructive/5",
    text: "text-destructive",
  },
  success: {
    title: "Success",
    icon: Tick02Icon,
    card: "bg-success/5",
    text: "text-success",
  },
  danger: {
    title: "Danger",
    icon: Cancel01Icon,
    card: "bg-destructive/5",
    text: "text-destructive",
  },
  info: {
    title: "Info",
    icon: InformationCircleIcon,
    card: "bg-info/5",
    text: "text-info",
  },
  warning: {
    title: "Warning",
    icon: Alert02Icon,
    card: "bg-warning/5",
    text: "text-warning",
  },
  alert: {
    title: "Alert",
    icon: Alert02Icon,
    card: "bg-warning/5",
    text: "text-warning",
  },
};

type VariantName = keyof typeof variants;
const variantKey: VariantName = Object.prototype.hasOwnProperty.call(
  variants,
  variant,
)
  ? (variant as VariantName)
  : "info";
const variantConfig = variants[variantKey];
const iconData = variantConfig.icon;
const heading = title ?? variantConfig.title;

const classes = cn(
  "rounded-lg  p-4 space-y-3",
  variantConfig.card,
  className,
);
const titleClasses = cn(
  "font-medium flex items-center gap-2",
  variantConfig.text,
);
---

<div class={classes} {...props}>
  <Text tag="h3" class={titleClasses}>
    <HugeIcon icon={iconData} size={16} />
    {heading}
  </Text>
  <slot />
</div>
